<h1><%= @place["name"] %></h1>

<h2>My Entries</h2>

<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4">
      <div class="card mb-3">
        <% if entry.image.attached? %>
          <img src="<%= url_for(entry.image) %>" class="card-img-top">
        <% end %>
        <div class="card-body">
          <h3 class="card-title"><%= entry["title"] %></h3>
          <h6 class="card-subtitle"><%= entry["occurred_on"] %></h6>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<p>
  <a href="/places/<%= @place["id"] %>/entries/new" class="btn btn-primary">New Entry</a>
</p>

<p>
  <a href="/places" class="btn btn-secondary">Back to All Places</a>
</p>
